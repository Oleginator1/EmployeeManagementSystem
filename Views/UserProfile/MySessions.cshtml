@model List<EmployeeManagementSystem.Models.Entities.UserSession>

@{
    ViewData["Title"] = "My Login History";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-clock-history"></i> My Login History
                    </h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Your last 20 login sessions. Review this regularly to detect any unauthorized access to your account.
                    </p>

                    @* Active Sessions Alert *@
                    @{
                        var activeSessions = Model.Where(s => s.Status == "Active").ToList();
                    }
                    @if (activeSessions.Any())
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            You have <strong>@activeSessions.Count</strong> active session(s) right now.
                            @if (activeSessions.Count > 1)
                            {
                                <span class="text-warning">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    Multiple sessions detected. If you don't recognize all devices, consider changing your password.
                                </span>
                            }
                        </div>
                    }

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Login Time</th>
                                        <th>Logout Time</th>
                                        <th>Duration</th>
                                        <th>Device</th>
                                        <th>Browser</th>
                                        <th>Location (IP)</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var session in Model)
                                    {
                                        <tr class="@(session.Status == "Active" ? "table-success" : "")">
                                            <td>
                                                <div>
                                                    <i class="bi bi-calendar"></i>
                                                    @session.LoginTime.ToString("MMM dd, yyyy")
                                                </div>
                                                <small class="text-muted">
                                                    @session.LoginTime.ToString("hh:mm tt")
                                                </small>
                                            </td>
                                            <td>
                                                @if (session.LogoutTime.HasValue)
                                                {
                                                    <div>
                                                        @session.LogoutTime.Value.ToString("MMM dd, yyyy")
                                                    </div>
                                                    <small class="text-muted">
                                                        @session.LogoutTime.Value.ToString("hh:mm tt")
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-success">
                                                        <i class="bi bi-circle-fill"></i> Active now
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (session.SessionDurationMinutes.HasValue)
                                                {
                                                    var duration = TimeSpan.FromMinutes(session.SessionDurationMinutes.Value);
                                                    if (duration.TotalHours >= 1)
                                                    {
                                                        <span>@((int)duration.TotalHours)h @duration.Minutes m</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@duration.Minutes min</span>
                                                    }
                                                }
                                                else if (session.Status == "Active")
                                                {
                                                    var currentDuration = DateTime.Now - session.LoginTime;
                                                    <span class="text-success">@((int)currentDuration.TotalMinutes) min</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <i class="bi bi-@(session.DeviceType?.ToLower() switch
                                                   {
                                                       "mobile" => "phone",
                                                       "tablet" => "tablet",
                                                       _ => "laptop"
                                                   })"></i>
                                        @session.DeviceType
                                    </td>
                                    <td>
                                        <i class="bi bi-@(session.Browser?.ToLower() switch
                                           {
                                               "chrome" => "browser-chrome",
                                               "firefox" => "browser-firefox",
                                               "edge" => "browser-edge",
                                               "safari" => "browser-safari",
                                               _ => "globe"
                                           })"></i>
                                        @session.Browser
                                    </td>
                                    <td>
                                        <code class="small">@session.IpAddress</code>
                                    </td>
                                    <td>
                                        @switch (session.Status)
                                                {
                                                    case "Active":
                                                        <span class="badge bg-success">
                                                            <i class="bi bi-circle-fill"></i> Active
                                                        </span>
                                                        break;
                                                    case "Ended":
                                                        <span class="badge bg-secondary">Ended</span>
                                                        break;
                                                    case "Expired":
                                                        <span class="badge bg-warning text-dark">Expired</span>
                                                        break;
                                                    case "ForcedLogout":
                                                        <span class="badge bg-danger">Forced</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @* Security Tips *@
                        <div class="alert alert-light mt-3">
                            <h6><i class="bi bi-shield-check"></i> Security Tips:</h6>
                            <ul class="mb-0 small">
                                <li>Review this list regularly to detect unauthorized access</li>
                                <li>If you see suspicious activity, change your password immediately</li>
                                <li>Use different passwords for different accounts</li>
                                <li>Enable two-factor authentication for extra security (if available)</li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center py-5">
                            <i class="bi bi-info-circle fs-1 d-block mb-3"></i>
                            <h5>No login history yet</h5>
                            <p class="mb-0">Your login sessions will appear here.</p>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>