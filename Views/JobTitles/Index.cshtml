@model EmployeeManagementSystem.Models.ViewModels.JobTitleSearchViewModel

@{
    ViewData["Title"] = "Job Titles";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h1 class="display-4">
                <i class="bi bi-briefcase"></i> Job Titles
            </h1>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Job Title
            </a>

            <a asp-action="ExportPdf"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-sortBy="@Model.SortBy"
               asp-route-sortOrder="@Model.SortOrder"
               class="btn btn-danger">
                <i class="bi bi-file-pdf"></i> Export PDF
            </a>
        </div>
    </div>

    @* Success/Error Messages *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Search Bar *@
    <div class="card mb-3">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-6">
                        <input type="text"
                               name="searchTerm"
                               value="@Model.SearchTerm"
                               class="form-control"
                               placeholder="Search job titles..." />
                    </div>
                    <div class="col-md-2">
                        <select name="pageSize" class="form-select">
                            <option value="10" selected="@(Model.PageSize == 10)">10 per page</option>
                            <option value="25" selected="@(Model.PageSize == 25)">25 per page</option>
                            <option value="50" selected="@(Model.PageSize == 50)">50 per page</option>
                            <option value="100" selected="@(Model.PageSize == 100)">100 per page</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-secondary w-100">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                    <div class="col-md-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-x-circle"></i> Clear
                        </a>
                    </div>
                </div>
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
            </form>
        </div>
    </div>

    @* Statistics Cards *@
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Job Titles</h6>
                            <h2 class="mb-0">@Model.TotalJobTitles</h2>
                        </div>
                        <i class="bi bi-briefcase-fill fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Employees</h6>
                            <h2 class="mb-0">@Model.TotalEmployees</h2>
                        </div>
                        <i class="bi bi-people fs-1"></i>
                    </div>
                </div>
            </div>
        </div>       
    </div>

    @* Results Info *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            Showing @((Model.PageNumber - 1) * Model.PageSize + 1)
            to @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))
            of @Model.TotalRecords job titles
        </div>
    </div>

    @* Job Titles Table *@
    <div class="card">
        <div class="card-body">
            @if (Model.JobTitles != null && Model.JobTitles.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>
                                    <a asp-action="Index"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-sortBy="title"
                                       asp-route-sortOrder="@(Model.SortBy == "title" && Model.SortOrder == "asc" ? "desc" : "asc")"
                                       asp-route-pageNumber="@Model.PageNumber"
                                       asp-route-pageSize="@Model.PageSize"
                                       class="text-white text-decoration-none">
                                        Job Title
                                        @if (Model.SortBy == "title")
                                        {
                                            <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </a>
                                </th>
                                <th>Description</th>
                                <th class="text-center">
                                    <a asp-action="Index"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-sortBy="employeecount"
                                       asp-route-sortOrder="@(Model.SortBy == "employeecount" && Model.SortOrder == "asc" ? "desc" : "asc")"
                                       asp-route-pageNumber="@Model.PageNumber"
                                       asp-route-pageSize="@Model.PageSize"
                                       class="text-white text-decoration-none">
                                        Employees
                                        @if (Model.SortBy == "employeecount")
                                        {
                                            <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </a>
                                </th>
                                <th class="text-center">Active</th>
                                <th>
                                    <a asp-action="Index"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-sortBy="created"
                                       asp-route-sortOrder="@(Model.SortBy == "created" && Model.SortOrder == "asc" ? "desc" : "asc")"
                                       asp-route-pageNumber="@Model.PageNumber"
                                       asp-route-pageSize="@Model.PageSize"
                                       class="text-white text-decoration-none">
                                        Created
                                        @if (Model.SortBy == "created")
                                        {
                                            <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </a>
                                </th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var jobTitle in Model.JobTitles)
                            {
                                <tr>
                                    <td>
                                        <strong>@jobTitle.TitleName</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(jobTitle.Description))
                                        {
                                            @(jobTitle.Description.Length > 50 ? jobTitle.Description.Substring(0, 50) + "..." : jobTitle.Description)
                                        }
                                        else
                                        {
                                            <span class="text-muted">No description</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-primary fs-6">@jobTitle.EmployeeCount</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success fs-6">@jobTitle.ActiveEmployeeCount</span>
                                    </td>
                                    <td>
                                        @jobTitle.CreatedDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details"
                                               asp-route-id="@jobTitle.JobTitleId"
                                               class="btn btn-sm btn-info"
                                               title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit"
                                               asp-route-id="@jobTitle.JobTitleId"
                                               class="btn btn-sm btn-warning"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (jobTitle.EmployeeCount == 0)
                                            {
                                                <a asp-action="Delete"
                                                   asp-route-id="@jobTitle.JobTitleId"
                                                   class="btn btn-sm btn-danger"
                                                   title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-secondary"
                                                        disabled
                                                        title="Cannot delete - has employees">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Pagination *@
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Job title pagination" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                                   asp-route-pageSize="@Model.PageSize">
                                    Previous
                                </a>
                            </li>

                            @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-sortBy="@Model.SortBy"
                                       asp-route-sortOrder="@Model.SortOrder"
                                       asp-route-pageNumber="@i"
                                       asp-route-pageSize="@Model.PageSize">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                                   asp-route-pageSize="@Model.PageSize">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No job titles found.
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <br />
                        <a asp-action="Index" class="alert-link">Clear search to see all job titles</a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}