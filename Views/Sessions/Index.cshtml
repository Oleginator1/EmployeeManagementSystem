@model EmployeeManagementSystem.Models.ViewModels.SessionManagementViewModel

@{
    ViewData["Title"] = "Session Management";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col">
            <h1 class="display-4">
                <i class="bi bi-shield-lock"></i> Session Management
            </h1>
        </div>
        <div class="col text-end">
            <a asp-action="ActiveSessions" class="btn btn-success">
                <i class="bi bi-circle-fill"></i> Active Sessions
            </a>
        </div>
    </div>

  
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Statistics Cards *@
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Active Now</h6>
                            <h2 class="mb-0">@Model.ActiveSessions</h2>
                        </div>
                        <i class="bi bi-people fs-1"></i>
                    </div>
                </div>
                <div class="card-footer bg-white bg-opacity-25">
                    <a asp-action="ActiveSessions" class="text-white text-decoration-none">
                        View All <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Sessions Today</h6>
                            <h2 class="mb-0">@Model.TotalSessionsToday</h2>
                        </div>
                        <i class="bi bi-calendar-check fs-1"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Unique Users</h6>
                            <h2 class="mb-0">@Model.UniqueUsersToday</h2>
                        </div>
                        <i class="bi bi-person-check fs-1"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Avg Session</h6>
                            <h2 class="mb-0">@Model.AverageSessionMinutes min</h2>
                        </div>
                        <i class="bi bi-clock fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Filters *@
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-funnel"></i> Filters
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Search</label>
                        <input asp-for="SearchTerm" class="form-control" placeholder="Email or IP..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Status</label>
                        <select asp-for="StatusFilter" class="form-select">
                            <option value="">All</option>
                            <option value="Active">Active</option>
                            <option value="Ended">Ended</option>
                            <option value="Expired">Expired</option>
                            <option value="ForcedLogout">Forced Logout</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Date From</label>
                        <input asp-for="DateFrom" type="date" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Date To</label>
                        <input asp-for="DateTo" type="date" class="form-control" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label">Per Page</label>
                        <select asp-for="PageSize" class="form-select">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* Results Info *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            Showing @((Model.PageNumber - 1) * Model.PageSize + 1)
            to @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))
            of @Model.TotalRecords sessions
        </div>
    </div>

    @* Sessions Table *@
    <div class="card">
        <div class="card-body">
            @if (Model.Sessions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>User</th>
                                <th>Role</th>
                                <th>Login Time</th>
                                <th>Logout Time</th>
                                <th>Duration</th>
                                <th>Device</th>
                                <th>Browser</th>
                                <th>IP Address</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in Model.Sessions)
                            {
                                <tr class="@(session.IsSuspicious ? "table-warning" : "")">
                                    <td>
                                        @session.UserEmail
                                        @if (session.IsSuspicious)
                                        {
                                            <i class="bi bi-exclamation-triangle text-warning" title="Suspicious"></i>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@session.UserRole</span>
                                    </td>
                                    <td>
                                        <small>@session.LoginTime.ToString("MM/dd/yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        @if (session.LogoutTime.HasValue)
                                        {
                                            <small>@session.LogoutTime.Value.ToString("MM/dd/yyyy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@session.Duration</td>
                                    <td>
                                        <i class="bi bi-@(session.DeviceType?.ToLower() switch
                                           {
                                               "mobile" => "phone",
                                               "tablet" => "tablet",
                                               _ => "laptop"
                                           })"></i>
                                @session.DeviceType
                            </td>
                            <td>@session.Browser</td>
                            <td><code>@session.IpAddress</code></td>
                            <td>
                                @switch (session.Status)
                                        {
                                            case "Active":
                                                <span class="badge bg-success">
                                                    <i class="bi bi-circle-fill"></i> Active
                                                </span>
                                                break;
                                            case "Ended":
                                                <span class="badge bg-secondary">Ended</span>
                                                break;
                                            case "Expired":
                                                <span class="badge bg-warning text-dark">Expired</span>
                                                break;
                                            case "ForcedLogout":
                                                <span class="badge bg-danger">Forced</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a asp-action="Details"
                                               asp-route-id="@session.SessionId"
                                               class="btn btn-sm btn-info"
                                               title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (session.IsActive)
                                            {
                                                <form asp-action="ForceLogout"
                                                      asp-route-id="@session.SessionId"
                                                      method="post"
                                                      style="display:inline"
                                                      onsubmit="return confirm('Force logout this session?')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-sm btn-danger"
                                                            title="Force Logout This Session">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-success rounded-circle me-2"
                                                 style="width: 10px; height: 10px;"
                                                 title="Active">
                                            </div>
                                            <div>
                                                <strong>@session.UserEmail</strong>
                                                @if (session.IsSuspicious)
                                                {
                                                    <i class="bi bi-exclamation-triangle text-warning ms-2"
                                                       title="Suspicious activity detected"></i>
                                                }
                                                <br />
                                                @if (session.IsActive)
                                                {
                                                    <form asp-action="ForceLogoutAllUser"
                                                          asp-route-userEmail="@session.UserEmail"
                                                          method="post"
                                                          style="display:inline"
                                                          onsubmit="return confirm('Force logout ALL sessions for @session.UserEmail?')">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit"
                                                                class="btn btn-xs btn-link text-danger p-0"
                                                                title="Force Logout All Sessions">
                                                            <small><i class="bi bi-x-circle-fill"></i> Logout all sessions</small>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Pagination *@
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Session pagination" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-statusFilter="@Model.StatusFilter"
                                   asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                                   asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                                   asp-route-pageSize="@Model.PageSize">
                                    Previous
                                </a>
                            </li>

                            @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-searchTerm="@Model.SearchTerm"
                                       asp-route-statusFilter="@Model.StatusFilter"
                                       asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                                       asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                                       asp-route-pageNumber="@i"
                                       asp-route-pageSize="@Model.PageSize">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-statusFilter="@Model.StatusFilter"
                                   asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                                   asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                                   asp-route-pageSize="@Model.PageSize">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No sessions found.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function() { $('.alert').fadeOut('slow'); }, 5000);
    </script>
}